{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021", "DOM", "WebWorker"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "downlevelIteration": true,
    "declaration": false,
    "noEmit": false,
    "noEmitOnError": false,
    "allowUnusedLabels": true,
    "allowUnreachableCode": true
  },
  "include": ["src", "rt"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/phase-18.disabled/**",
    "src/parser-extensions.bak/**",
    "src/ffi/c-function-caller.ts",
    "src/stdlib-log-streamer.ts",
    "src/stdlib-native-request-recorder.ts",
    "src/stdlib/vault.ts",
    "src/stdlib/sqlite-native.ts"
  ]
}
