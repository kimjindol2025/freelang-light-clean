# ============================================================================
# FreeLang Light - Database Configuration
# ============================================================================
# docker-compose.yml의 postgres 서비스에서 로드

# PostgreSQL 기본 설정
POSTGRES_DB=freelang
POSTGRES_USER=freelang
POSTGRES_PASSWORD=freelang123

# 성능 튜닝
POSTGRES_INITDB_ARGS=-c shared_buffers=256MB -c max_connections=200 -c effective_cache_size=1GB

# 포트
POSTGRES_PORT=5432

# 로깅
POSTGRES_LOG_LEVEL=notice
POSTGRES_LOG_MIN_DURATION_STATEMENT=1000

# 연결 풀 (pgBouncer와 함께 사용하는 경우)
# DB_POOL_MIN=5
# DB_POOL_MAX=20
# DB_POOL_TIMEOUT=30

# 마이그레이션
DB_MIGRATION_AUTO=true
DB_BACKUP_ENABLED=true
DB_BACKUP_INTERVAL=3600  # 1시간

# 개발/테스트 모드
# POSTGRES_INITDB_ARGS=-c log_statement=all
