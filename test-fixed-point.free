// ============================================================
// Fixed Point 검증 테스트
//
// 간단한 숫자 연산으로 자체호스팅 증명:
// Step 1: 원본 코드 → Lexer → Parser → IR Gen → 실행
// Step 2: 생성된 IR를 다시 컴파일 → 실행
// Step 3: Result1 == Result2 확인 → Fixed Point!
// ============================================================

// 테스트 1: 기본 산술 연산
let x = 10;
let y = 20;
let z = x + y;

// 테스트 2: 조건문
if (z > 25) {
    z = z * 2;
}

// 테스트 3: 반복문
let sum = 0;
let i = 0;
while (i < 5) {
    sum = sum + i;
    i = i + 1;
}

// 테스트 4: 함수 호출
fn add(a, b) {
    return a + b;
}

let result = add(3, 7);

// 최종 결과 (모두 더하기)
let final = z + sum + result;
