// ============================================================================
// PART 5: 기간별 보고서
// ============================================================================

pub fn generate_daily_report(date: string) -> AnalyticsReport
  intent "일일 분석 보고서"
  do
    let report = AnalyticsReport {
      period_start: date + "T00:00:00Z",
      period_end: date + "T23:59:59Z",
      total_posts: 0,
      total_comments: 0,
      total_likes: 0,
      engagement_rate: 0.0,
      trending_topics: get_trending_topics(5)
    }

    // TODO: 메트릭 집계

    println("📅 일일 보고서 생성: " + date)
    return report
  end

pub fn generate_weekly_report(week_start: string) -> AnalyticsReport
  intent "주간 분석 보고서"
  do
    let report = AnalyticsReport {
      period_start: week_start,
      period_end: add_days(week_start, 7),
      total_posts: 0,
      total_comments: 0,
      total_likes: 0,
      engagement_rate: 0.0,
      trending_topics: get_trending_topics(10)
    }

    println("📊 주간 보고서 생성: " + week_start + " ~ " + report.period_end)
    return report
  end

pub fn generate_monthly_report(year: i32, month: i32) -> AnalyticsReport
  intent "월간 분석 보고서"
  do
    let period_start = int_to_string(year) + "-" + pad_zero(month, 2) + "-01"

    let report = AnalyticsReport {
      period_start: period_start,
      period_end: add_days(period_start, 30),
      total_posts: 0,
      total_comments: 0,
      total_likes: 0,
      engagement_rate: 0.0,
      trending_topics: get_trending_topics(20)
    }

    println("📈 월간 보고서 생성: " + int_to_string(year) + "-" + int_to_string(month))
    return report
  end

// ============================================================================
// PART 6: 메트릭 내보내기
// ============================================================================

pub fn export_metrics_csv(metric_name: string, start_time: string, end_time: string) -> string
  intent "메트릭을 CSV로 내보내기"
  do
    let csv = "timestamp,metric_name,value\n"

    for i = 0; i < length(GLOBAL_METRICS); i++
      let metric = GLOBAL_METRICS[i]

      if metric.metric_name == metric_name
        csv = csv + metric.timestamp + "," + metric.metric_name + "," + format_float(metric.value) + "\n"
      end
    end

    println("📥 메트릭 내보내기: " + metric_name + " (" + int_to_string(length(GLOBAL_METRICS)) + " 데이터 포인트)")
    return csv
  end

pub fn export_metrics_json() -> string
  intent "모든 메트릭을 JSON으로 내보내기"
  do
    let json = "{"
    json = json + "\"metrics\": ["

    for i = 0; i < length(GLOBAL_METRICS); i++
      let metric = GLOBAL_METRICS[i]
      json = json + "{"
      json = json + "\"timestamp\": \"" + metric.timestamp + "\","
      json = json + "\"name\": \"" + metric.metric_name + "\","
      json = json + "\"value\": " + format_float(metric.value)
      json = json + "}"

      if i < length(GLOBAL_METRICS) - 1
        json = json + ","
      end
    end

    json = json + "]}"
    println("📥 모든 메트릭 JSON 내보내기 (" + int_to_string(length(GLOBAL_METRICS)) + " 포인트)")
    return json
  end

// ============================================================================
// PART 7: 알림 & 임계값
// ============================================================================

pub fn check_alert_thresholds() -> array<string>
  intent "성능 임계값 초과 확인"
  do
    let alerts: array<string> = []

    // 응답시간 임계값 (500ms)
    if GLOBAL_PERFORMANCE.avg_response_time_ms > 500.0
      alerts = array_append_str(alerts, "⚠️ 높은 응답시간: " + format_float(GLOBAL_PERFORMANCE.avg_response_time_ms) + "ms")
    end

    // 에러율 임계값 (5%)
    if GLOBAL_PERFORMANCE.error_rate_percent > 5.0
      alerts = array_append_str(alerts, "⚠️ 높은 에러율: " + format_float(GLOBAL_PERFORMANCE.error_rate_percent) + "%")
    end

    // 캐시 히트율 임계값 (50% 미만)
    if GLOBAL_PERFORMANCE.cache_hit_rate_percent < 50.0
      alerts = array_append_str(alerts, "⚠️ 낮은 캐시 히트율: " + format_float(GLOBAL_PERFORMANCE.cache_hit_rate_percent) + "%")
    end

    return alerts
  end

pub fn print_metrics_summary() -> void
  intent "메트릭 요약 출력"
  do
    println("")
    println("📊 === 메트릭 요약 ===")
    println("   페이지뷰: " + int_to_string(GLOBAL_PAGE_VIEWS.total_views))
    println("   방문자: " + int_to_string(GLOBAL_PAGE_VIEWS.unique_visitors))
    println("   평균 응답시간: " + format_float(GLOBAL_PERFORMANCE.avg_response_time_ms) + "ms")
    println("   에러율: " + format_float(GLOBAL_PERFORMANCE.error_rate_percent) + "%")
    println("   캐시 히트율: " + format_float(GLOBAL_PERFORMANCE.cache_hit_rate_percent) + "%")

    let alerts = check_alert_thresholds()
    if length(alerts) > 0
      println("   경고:")
      for i = 0; i < length(alerts); i++
        println("     " + alerts[i])
      end
    end

    println("")
  end

// ============================================================================
// PART 8: 내부 헬퍼 함수
// ============================================================================

fn calculate_average(values: array<i32>) -> f64
  intent "배열의 평균값 계산"
  do
    if length(values) == 0 return 0.0 end
    let sum = 0.0
    for i = 0; i < length(values); i++
      sum = sum + (values[i] as f64)
    end
    return sum / (length(values) as f64)
  end

fn calculate_percentile(values: array<i32>, percentile: f64) -> f64
  intent "백분위수 계산"
  do
    // 간단한 구현: 정렬 후 인덱스 계산
    let index = ((percentile / 100.0) * (length(values) as f64) as i32)
    if index >= length(values) index = length(values) - 1 end
    return (values[index] as f64)
  end

fn get_current_time() -> string
  intent "현재 시간"
  do
    return "2026-03-13T12:00:00Z"
  end

fn add_days(date: string, days: i32) -> string
  intent "날짜에 일수 추가"
  do
    return date  // TODO: 실제 날짜 계산
  end

fn pad_zero(n: i32, width: i32) -> string
  intent "숫자 앞에 0 패딩"
  do
    let s = int_to_string(n)
    while length(s) < width
      s = "0" + s
    end
    return s
  end

fn int_to_string(n: i32) -> string
  intent "정수를 문자열로"
  do
    return to_string(n)
  end

fn format_float(f: f64) -> string
  intent "실수 포맷팅"
  do
    let int_part = (f as i32)
    let frac_part = ((f - (int_part as f64)) * 100.0 as i32)
    return int_to_string(int_part) + "." + int_to_string(frac_part)
  end

fn length(s: string) -> i32
  intent "길이"
  do
    return string_length(s)
  end

