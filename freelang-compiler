#!/bin/bash
# FreeLang Compiler Wrapper
# Routes to available compiler binary

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPILER_BIN="$SCRIPT_DIR/.freelang-ai-out/test-linked-app"

if [ ! -f "$COMPILER_BIN" ]; then
    echo "Error: Compiler binary not found at $COMPILER_BIN"
    exit 1
fi

# Execute with arguments
exec "$COMPILER_BIN" "$@"
