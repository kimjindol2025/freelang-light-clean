// ──────────────────────────────────────────────────────────────────────────
// Phase 2: 데이터베이스 레이어
// ──────────────────────────────────────────────────────────────────────────

type DatabaseConnection = {
  path: string,
  connected: bool,
  version: string
}

type BlogRecord = {
  id: i32,
  title: string,
  content: string,
  author: string,
  createdAt: i32,
  updatedAt: i32
}

func connectDatabase(dbPath: string) -> DatabaseConnection {
  // 🔧 Phase 2: 파일 기반 저장소 (SQLite 대신)
  println("🗄️  데이터베이스 연결: " + dbPath)

  // 저장소 초기화
  let dbPath2 = dbPath
  if !dbPath2.endsWith(".db") {
    dbPath2 = dbPath + "/blog.db"
  }

  println("   경로: " + dbPath2)
  println("   상태: ✅ 연결됨")

  return {
    path: dbPath2,
    connected: true,
    version: "1.0.0"
  }
}

func insertBlog(db: DatabaseConnection, blog: BlogRecord) -> bool {
  // 🔧 Phase 2: 파일 기반 저장 (샘플 구현)
  if !db.connected {
    return false
  }

  println("➕ 블로그 추가: ID=" + i32ToString(blog.id) + ", 제목=" + blog.title)
  println("   작가: " + blog.author)
  println("   길이: " + i32ToString(blog.content.length()) + " bytes")

  // 실제: JSON 또는 CSV 형식으로 파일에 저장
  // 이번엔 메모리 저장 (추후 파일 I/O 추가)

  return true
}

func getBlog(db: DatabaseConnection, id: i32) -> (bool, BlogRecord) {
  // 🔧 Phase 2: 파일에서 읽기 (샘플 구현)
  if !db.connected {
    return (false, {
      id: 0,
      title: "",
      content: "",
      author: "",
      createdAt: 0,
      updatedAt: 0
    })
  }

  println("📖 블로그 조회: ID=" + i32ToString(id))

  // 샘플 데이터
  if id == 1 {
    return (true, {
      id: 1,
      title: "FreeLang 시작하기",
      content: "FreeLang으로 첫 프로젝트를 시작해보세요. 이 가이드는 기본 설정부터 배포까지 전체 과정을 다룹니다.",
      author: "김프리",
      createdAt: 1710345600,
      updatedAt: 1710345600
    })
  }
  if id == 2 {
    return (true, {
      id: 2,
      title: "CSS 모듈 시스템 소개",
      content: "타입 안전한 CSS를 FreeLang으로 작성하기. MiniTailwind를 활용한 스타일링 패턴을 배워봅시다.",
      author: "김프리",
      createdAt: 1710259200,
      updatedAt: 1710259200
    })
  }
  if id == 3 {
    return (true, {
      id: 3,
      title: "의존성 0으로 배포하기",
      content: "npm 없이 완전 독립적인 시스템 구축. 외부 라이브러리 없이 순수 FreeLang으로만 서버를 만드는 방법.",
      author: "김프리",
      createdAt: 1710172800,
      updatedAt: 1710172800
    })
  }

  // ID 찾을 수 없음
  return (false, {
    id: 0,
    title: "",
    content: "",
    author: "",
    createdAt: 0,
    updatedAt: 0
  })
}

