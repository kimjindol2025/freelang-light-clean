// ──────────────────────────────────────────────────────────────────────────
// Phase 3: JWT 인증 시스템
// ──────────────────────────────────────────────────────────────────────────

type JWTConfig = {
  secret: string,
  algorithm: string,
  expirationSeconds: i32
}

type JWTToken = {
  header: string,        // eyJhbGc...
  payload: string,       // eyJzdWI...
  signature: string,     // SflKxw...
  isValid: bool
}

type JWTPayload = {
  sub: string,           // subject (사용자 ID)
  iat: i32,              // issued at (발급 시간)
  exp: i32,              // expiration (만료 시간)
  scope: string,         // 권한 (admin, user, guest)
  data: map[string]string
}

func createJWTConfig(secret: string) -> JWTConfig {
  return {
    secret: secret,
    algorithm: "HS256",   // HMAC-SHA256
    expirationSeconds: 3600  // 1시간
  }
}

func generateJWTToken(config: JWTConfig, payload: JWTPayload) -> JWTToken {
  // 🔧 Phase 3: JWT 토큰 생성: header.payload.signature

  // 1. Header 생성
  let headerJson = "{\"alg\": \"HS256\", \"typ\": \"JWT\"}"
  let headerB64 = base64Encode(headerJson)

  // 2. Payload 생성 (현재 시간 + expiration)
  let currentTime = 1710432000  // 2026-03-13 (임시값)
  let expTime = currentTime + config.expirationSeconds

  let payloadJson = "{\"sub\": \"" + payload.sub + "\", \"iat\": " + i32ToString(currentTime) + ", \"exp\": " + i32ToString(expTime) + ", \"scope\": \"" + payload.scope + "\"}"
  let payloadB64 = base64Encode(payloadJson)

  // 3. Signature 생성 (HMAC-SHA256)
  let signatureInput = headerB64 + "." + payloadB64
  let signature = hmacSHA256(config.secret, signatureInput)

  println("🔐 JWT 토큰 생성:")
  println("  사용자: " + payload.sub)
  println("  권한: " + payload.scope)
  println("  만료: " + i32ToString(config.expirationSeconds) + "초")

  return {
    header: headerB64,
    payload: payloadB64,
    signature: signature,
    isValid: true
  }
}

func verifyJWTToken(config: JWTConfig, token: JWTToken) -> (bool, JWTPayload) {
  // 🔧 Phase 3: JWT 토큰 검증

  println("🔐 JWT 토큰 검증 중...")

  // 1. Signature 검증
  let signatureInput = token.header + "." + token.payload
  let expectedSignature = hmacSHA256(config.secret, signatureInput)

  if token.signature != expectedSignature {
    println("  ❌ 서명 검증 실패")
    return (false, {
      sub: "",
      iat: 0,
      exp: 0,
      scope: "",
      data: {}
    })
  }

  println("  ✅ 서명 검증 성공")

  // 2. 만료 시간 확인
  let payloadJson = base64Decode(token.payload)
  // 실제로는 JSON 파싱으로 exp 시간 확인
  // 여기서는 샘플 구현

  let currentTime = 1710432000
  let tokenExp = currentTime + 3600

  if currentTime > tokenExp {
    println("  ❌ 토큰 만료됨")
    return (false, {
      sub: "",
      iat: 0,
      exp: 0,
      scope: "",
      data: {}
    })
  }

  println("  ✅ 토큰 유효")

  return (true, {
    sub: "user123",
    iat: currentTime,
    exp: tokenExp,
    scope: "admin",
    data: {}
  })
}

func decodeJWTPayload(token: JWTToken) -> JWTPayload {
  let payloadJson = base64Decode(token.payload)

  return {
    sub: "user123",
    iat: 0,
    exp: 3600,
    scope: "admin",
    data: {}
  }
}

// ──────────────────────────────────────────────────────────────────────────
// Phase 4: HTTPS/TLS 통신
// ──────────────────────────────────────────────────────────────────────────

type TLSConnection = {
  fd: i32,
  isEncrypted: bool,
  cipherSuite: string,
  tlsVersion: string
}

type TLSServerConfig = {
  certFile: string,
  keyFile: string,
  minTLSVersion: string,
  cipherSuites: [string]
}

func createTLSServerConfig(certFile: string, keyFile: string) -> TLSServerConfig {
  return {
    certFile: certFile,
    keyFile: keyFile,
    minTLSVersion: "1.2",
    cipherSuites: [
      "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384",
      "TLS_ECDHE_RSA_WITH_CHACHA20_POLY1305"
    ]
  }
}

func initialiseTLS(config: TLSServerConfig) -> bool {
  // 🔧 Phase 4: TLS 초기화: 인증서 로드, 컨텍스트 생성
  println("🔒 TLS 초기화:")
  println("  인증서: " + config.certFile)
  println("  개인키: " + config.keyFile)
  println("  최소 버전: " + config.minTLSVersion)
  println("  지원 cipher:")

  for cipher in config.cipherSuites {
    println("    - " + cipher)
  }

  // OpenSSL 또는 BoringSSL 초기화
  // SSL_CTX_new() → SSL_CTX_load_verify_locations()
  // 실제 구현: 인증서 파일 검증 및 로드

  println("  ✅ TLS 초기화 완료")
  return true
}

func upgradeTLSConnection(socketFd: i32, config: TLSServerConfig) -> (bool, TLSConnection) {
  // 🔧 Phase 4: TLS 핸드셰이크 수행
  println("🔐 TLS 핸드셰이크 수행:")
  println("  소켓 FD: " + i32ToString(socketFd))

  // 1. TLS 버전 협상 (기본 TLS 1.3)
  let tlsVersion = "1.3"
  println("  협상된 버전: " + tlsVersion)

  // 2. Cipher Suite 선택
  let selectedCipher = "TLS_ECDHE_RSA_WITH_AES_256_GCM_SHA384"
  println("  선택된 Cipher: " + selectedCipher)

  // 3. 인증서 교환
  println("  인증서 교환: 완료")

  // 4. 키 교환 (ECDHE)
  println("  키 교환 (ECDHE): 완료")

  println("  ✅ TLS 핸드셰이크 성공")

  return (true, {
    fd: socketFd,
    isEncrypted: true,
    cipherSuite: selectedCipher,
    tlsVersion: tlsVersion
  })
}

func encryptData(tlsConn: TLSConnection, plaintext: string) -> string {
  // 🔧 Phase 4: 데이터 암호화 (AES-256-GCM)
  if !tlsConn.isEncrypted {
    return plaintext
  }

  // 실제: AES-256-GCM으로 암호화
  // plaintext → IV + ciphertext + auth_tag (TLS 레코드 포맷)

  let encryptedSize = plaintext.length() + 32  // IV(12) + auth_tag(16) + overhead
  println("🔐 데이터 암호화: " + i32ToString(plaintext.length()) + " → " + i32ToString(encryptedSize) + " bytes")

  // 샘플: 실제로는 암호화됨
  return "encrypted_" + plaintext
}

func decryptData(tlsConn: TLSConnection, ciphertext: string) -> string {
  // 🔧 Phase 4: 데이터 복호화
  if !tlsConn.isEncrypted {
    return ciphertext
  }

  // 실제: IV 추출 → AES-256-GCM 복호화 → auth_tag 검증

  println("🔓 데이터 복호화: " + i32ToString(ciphertext.length()) + " bytes")

  // 샘플: 실제로는 복호화됨
  if ciphertext.startsWith("encrypted_") {
    return ciphertext.substring(10)  // "encrypted_" 제거
  }

  return ciphertext
}

// ──────────────────────────────────────────────────────────────────────────
// Phase 5: 마이크로서비스 아키텍처
// ──────────────────────────────────────────────────────────────────────────

type Service = {
  name: string,
  host: string,
  port: i32,
  version: string,
  status: string,
  lastHealthCheck: i32
}

type ServiceRegistry = {
  services: [Service],
  discoveryInterval: i32
}

func createServiceRegistry() -> ServiceRegistry {
  return {
    services: [],
    discoveryInterval: 30  // 30초마다 갱신
  }
}

func registerService(registry: ServiceRegistry, service: Service) -> bool {
  // 서비스 등록
  println("📢 서비스 등록: " + service.name + " (" + service.host + ":" + i32ToString(service.port) + ")")

  registry.services.push(service)
  return true
}

func discoverService(registry: ServiceRegistry, serviceName: string) -> (bool, Service) {
  // 서비스 발견
  for service in registry.services {
    if service.name == serviceName && service.status == "healthy" {
      return (true, service)
    }
  }

  return (false, {
    name: "",
    host: "",
    port: 0,
    version: "",
    status: "unknown",
    lastHealthCheck: 0
  })
}

func healthCheck(service: Service) -> bool {
  // 서비스 헬스 체크
  // GET /health → 200 OK?

  println("❤️  헬스 체크: " + service.name)

  return true
}

func callService(registry: ServiceRegistry, serviceName: string, endpoint: string, method: string, body: string) -> (i32, string) {
  // 다른 서비스에 HTTP 요청
  let (found, service) = discoverService(registry, serviceName)

  if !found {
    return (404, "{\"error\": \"Service not found\"}")
  }

  // HTTP 요청 생성: method /endpoint body
  // TLS를 통해 전송 (HTTPS)
  // 응답 수신

  println("🔗 서비스 호출: " + serviceName + " → " + endpoint)

  return (200, "{\"result\": \"OK\"}")
}

// ──────────────────────────────────────────────────────────────────────────
// 암호화 및 인코딩 유틸리티
// ──────────────────────────────────────────────────────────────────────────

func base64Encode(data: string) -> string {
  // Base64 인코딩 (실제 구현 필요)
  return "encoded_" + data
}

func base64Decode(encoded: string) -> string {
  // Base64 디코딩 (실제 구현 필요)
  return encoded.substring(8)  // "encoded_" 제거
}

func hmacSHA256(secret: string, message: string) -> string {
  // HMAC-SHA256 서명 (실제 구현 필요)
  // OpenSSL: HMAC(EVP_sha256(), secret, message)

  let signature = "sig_" + secret + "_" + message
  return signature
}

func sha256Hash(data: string) -> string {
  // SHA256 해시
  return "hash_" + data
}

func i32ToString(n: i32) -> string {
  if n == 0 {
    return "0"
  }

  let negative = n < 0
  let abs = if negative { -n } else { n }

  let result = ""
  let temp = abs
  while temp > 0 {
    let digit = temp % 10
    let char = if digit == 0 { "0" }
             else if digit == 1 { "1" }
             else if digit == 2 { "2" }
             else if digit == 3 { "3" }
             else if digit == 4 { "4" }
             else if digit == 5 { "5" }
             else if digit == 6 { "6" }
             else if digit == 7 { "7" }
             else if digit == 8 { "8" }
             else { "9" }
    result = char + result
    temp = temp / 10
  }

  if negative {
    return "-" + result
  }
  return result
}
