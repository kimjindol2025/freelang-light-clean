// FreeLang Self-Hosting: Full Lexer (Phase 3A)
// Ported from src/lexer/token.ts + src/lexer/lexer.ts
// 140+ token types, full keyword recognition, string/number/comment support

// ── Character classification ──

fn isAlpha(ch) {
  return (ch >= "a" && ch <= "z") || (ch >= "A" && ch <= "Z") || ch == "_";
}

fn isDigit(ch) {
  return ch >= "0" && ch <= "9";
}

fn isAlphaNumeric(ch) {
  return isAlpha(ch) || isDigit(ch);
}

fn isWhitespace(ch) {
  return ch == " " || ch == "\t" || ch == "\r";
}

// ── Keyword lookup ──

fn getKeywordType(word) {
  // Core keywords
  if word == "fn" { return "FN"; }
  if word == "let" { return "LET"; }
  if word == "var" { return "LET"; }
  if word == "const" { return "CONST"; }
  if word == "if" { return "IF"; }
  if word == "else" { return "ELSE"; }
  if word == "match" { return "MATCH"; }
  if word == "for" { return "FOR"; }
  if word == "while" { return "WHILE"; }
  if word == "loop" { return "LOOP"; }
  if word == "break" { return "BREAK"; }
  if word == "continue" { return "CONTINUE"; }
  if word == "return" { return "RETURN"; }
  if word == "async" { return "ASYNC"; }
  if word == "await" { return "AWAIT"; }
  if word == "import" { return "IMPORT"; }
  if word == "export" { return "EXPORT"; }
  if word == "from" { return "FROM"; }
  if word == "struct" { return "STRUCT"; }
  if word == "enum" { return "ENUM"; }
  if word == "trait" { return "TRAIT"; }
  if word == "type" { return "TYPE"; }
  if word == "true" { return "TRUE"; }
  if word == "false" { return "FALSE"; }
  if word == "null" { return "NULL"; }
  if word == "in" { return "IN"; }
  if word == "of" { return "OF"; }
  if word == "as" { return "AS"; }
  if word == "is" { return "IS"; }
  if word == "pub" { return "PUB"; }
  if word == "mut" { return "MUT"; }
  if word == "self" { return "SELF"; }
  if word == "super" { return "SUPER"; }
  if word == "impl" { return "IMPL"; }

  // Exception handling
  if word == "try" { return "TRY"; }
  if word == "catch" { return "CATCH"; }
  if word == "throw" { return "THROW"; }
  if word == "finally" { return "FINALLY"; }

  // Phase 5 .free format
  if word == "input" { return "INPUT"; }
  if word == "output" { return "OUTPUT"; }
  if word == "intent" { return "INTENT"; }

  // Special
  if word == "secret" { return "SECRET"; }
  if word == "style" { return "STYLE"; }
  if word == "test" { return "TEST"; }
  if word == "expect" { return "EXPECT"; }
  if word == "schema" { return "SCHEMA"; }
  if word == "resolver" { return "RESOLVER"; }
  if word == "query" { return "QUERY"; }
  if word == "mutation" { return "MUTATION"; }

  return "IDENT";
}

// ── Make token helper ──

fn makeToken(tp, val, ln, cl) {
  return { type: tp, value: val, line: ln, column: cl };
}

// ── Main tokenizer ──

fn tokenize(source) {
  let tokens = [];
  let pos = 0;
  let line = 1;
  let col = 1;
  let len = length(source);

  while pos < len {
    let ch = char_at(source, pos);

    // Whitespace
    if isWhitespace(ch) {
      pos = pos + 1;
      col = col + 1;
      continue;
    }

    // Newline
    if ch == "\n" {
      pos = pos + 1;
      line = line + 1;
      col = 1;
      continue;
    }

    // Single-line comment: //
    if ch == "/" && pos + 1 < len && char_at(source, pos + 1) == "/" {
      pos = pos + 2;
      while pos < len && char_at(source, pos) != "\n" {
        pos = pos + 1;
      }
      continue;
    }

    // Multi-line comment: /* ... */
    if ch == "/" && pos + 1 < len && char_at(source, pos + 1) == "*" {
      pos = pos + 2;
      col = col + 2;
      while pos + 1 < len {
        if char_at(source, pos) == "*" && char_at(source, pos + 1) == "/" {
          pos = pos + 2;
          col = col + 2;
          break;
        }
        if char_at(source, pos) == "\n" {
          line = line + 1;
          col = 1;
        } else {
          col = col + 1;
        }
        pos = pos + 1;
      }
      continue;
    }

    // String literal: "..." or '...'
    if ch == "\"" || ch == "'" {
      let quote = ch;
      let startCol = col;
      pos = pos + 1;
      col = col + 1;
      let strVal = "";
      while pos < len && char_at(source, pos) != quote {
        let c = char_at(source, pos);
        if c == "\\" && pos + 1 < len {
          let next = char_at(source, pos + 1);
          if next == "n" { strVal = strVal + "\n"; }
          else if next == "t" { strVal = strVal + "\t"; }
          else if next == "\\" { strVal = strVal + "\\"; }
          else if next == "\"" { strVal = strVal + "\""; }
          else if next == "'" { strVal = strVal + "'"; }
          else { strVal = strVal + next; }
          pos = pos + 2;
          col = col + 2;
        } else {
          strVal = strVal + c;
          pos = pos + 1;
          col = col + 1;
        }
      }
      if pos < len { pos = pos + 1; col = col + 1; }
      push(tokens, makeToken("STRING", strVal, line, startCol));
      continue;
    }

    // Number literal
    if isDigit(ch) {
      let start = pos;
      let startCol = col;
      while pos < len && isDigit(char_at(source, pos)) {
        pos = pos + 1;
        col = col + 1;
      }
      // Decimal point
      if pos < len && char_at(source, pos) == "." && pos + 1 < len && isDigit(char_at(source, pos + 1)) {
        pos = pos + 1;
        col = col + 1;
        while pos < len && isDigit(char_at(source, pos)) {
          pos = pos + 1;
          col = col + 1;
        }
      }
      push(tokens, makeToken("NUMBER", slice(source, start, pos), line, startCol));
      continue;
    }

    // Identifier or keyword
    if isAlpha(ch) {
      let start = pos;
      let startCol = col;
      while pos < len && isAlphaNumeric(char_at(source, pos)) {
        pos = pos + 1;
        col = col + 1;
      }
      let word = slice(source, start, pos);
      let tokType = getKeywordType(word);
      push(tokens, makeToken(tokType, word, line, startCol));
      continue;
    }

    // Two-character operators (check before single-char)
    let startCol = col;

    if ch == "=" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("EQ", "==", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "!" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("NE", "!=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "<" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("LE", "<=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == ">" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("GE", ">=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "&" && pos + 1 < len && char_at(source, pos + 1) == "&" {
      push(tokens, makeToken("AND", "&&", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "|" && pos + 1 < len && char_at(source, pos + 1) == "|" {
      push(tokens, makeToken("OR", "||", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "=" && pos + 1 < len && char_at(source, pos + 1) == ">" {
      push(tokens, makeToken("FAT_ARROW", "=>", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "-" && pos + 1 < len && char_at(source, pos + 1) == ">" {
      push(tokens, makeToken("ARROW", "->", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "*" && pos + 1 < len && char_at(source, pos + 1) == "*" {
      push(tokens, makeToken("POWER", "**", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "." && pos + 1 < len && char_at(source, pos + 1) == "." {
      if pos + 2 < len && char_at(source, pos + 2) == "=" {
        push(tokens, makeToken("RANGE_INC", "..=", line, startCol));
        pos = pos + 3; col = col + 3; continue;
      }
      push(tokens, makeToken("RANGE", "..", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == ":" && pos + 1 < len && char_at(source, pos + 1) == ":" {
      push(tokens, makeToken("COLON_COLON", "::", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "|" && pos + 1 < len && char_at(source, pos + 1) == ">" {
      push(tokens, makeToken("PIPE_GT", "|>", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "<" && pos + 1 < len && char_at(source, pos + 1) == "<" {
      push(tokens, makeToken("SHL", "<<", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == ">" && pos + 1 < len && char_at(source, pos + 1) == ">" {
      push(tokens, makeToken("SHR", ">>", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }

    // Compound assignment operators
    if ch == "+" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("PLUS_ASSIGN", "+=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "-" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("MINUS_ASSIGN", "-=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "*" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("STAR_ASSIGN", "*=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "/" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("SLASH_ASSIGN", "/=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }
    if ch == "%" && pos + 1 < len && char_at(source, pos + 1) == "=" {
      push(tokens, makeToken("PERCENT_ASSIGN", "%=", line, startCol));
      pos = pos + 2; col = col + 2; continue;
    }

    // Single-character operators
    if ch == "+" { push(tokens, makeToken("PLUS", "+", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "-" { push(tokens, makeToken("MINUS", "-", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "*" { push(tokens, makeToken("STAR", "*", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "/" { push(tokens, makeToken("SLASH", "/", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "%" { push(tokens, makeToken("PERCENT", "%", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "=" { push(tokens, makeToken("ASSIGN", "=", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "<" { push(tokens, makeToken("LT", "<", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == ">" { push(tokens, makeToken("GT", ">", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "!" { push(tokens, makeToken("NOT", "!", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "&" { push(tokens, makeToken("BIT_AND", "&", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "|" { push(tokens, makeToken("BIT_OR", "|", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "^" { push(tokens, makeToken("BIT_XOR", "^", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "~" { push(tokens, makeToken("BIT_NOT", "~", line, startCol)); pos = pos + 1; col = col + 1; continue; }

    // Delimiters
    if ch == "(" { push(tokens, makeToken("LPAREN", "(", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == ")" { push(tokens, makeToken("RPAREN", ")", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "[" { push(tokens, makeToken("LBRACKET", "[", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "]" { push(tokens, makeToken("RBRACKET", "]", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "{" { push(tokens, makeToken("LBRACE", "{", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "}" { push(tokens, makeToken("RBRACE", "}", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "," { push(tokens, makeToken("COMMA", ",", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == ";" { push(tokens, makeToken("SEMICOLON", ";", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == ":" { push(tokens, makeToken("COLON", ":", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "." { push(tokens, makeToken("DOT", ".", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "?" { push(tokens, makeToken("QUESTION", "?", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "@" { push(tokens, makeToken("AT", "@", line, startCol)); pos = pos + 1; col = col + 1; continue; }
    if ch == "#" { push(tokens, makeToken("HASH", "#", line, startCol)); pos = pos + 1; col = col + 1; continue; }

    // Unknown character — skip
    pos = pos + 1;
    col = col + 1;
  }

  // EOF token
  push(tokens, makeToken("EOF", "", line, col));
  return tokens;
}
// Minimal self-hosting parser - separated from lexer

fn peek(p) { return p.tokens[p.pos]; }
fn adv(p) { let t = peek(p); p.pos = p.pos + 1; return t; }

fn chk(p, tp) {
  if peek(p).type == tp { return true; }
  return false;
}

fn atEnd(p) {
  if peek(p).type == "EOF" { return true; }
  return false;
}

fn skipSemi(p) {
  while chk(p, "SEMICOLON") { adv(p); }
}

// Forward declarations via mutual recursion

fn parseExpr(p) {
  return parseOr(p);
}

fn parseOr(p) {
  let left = parseAnd(p);
  while chk(p, "OR") { adv(p); left = { type: "binary", op: "||", left: left, right: parseAnd(p) }; }
  return left;
}

fn parseAnd(p) {
  let left = parseEq(p);
  while chk(p, "AND") { adv(p); left = { type: "binary", op: "&&", left: left, right: parseEq(p) }; }
  return left;
}

fn parseEq(p) {
  let left = parseCmp(p);
  while chk(p, "EQ") || chk(p, "NE") { let op = adv(p).value; left = { type: "binary", op: op, left: left, right: parseCmp(p) }; }
  return left;
}

fn parseCmp(p) {
  let left = parseAdd(p);
  while chk(p, "LT") || chk(p, "GT") || chk(p, "LE") || chk(p, "GE") { let op = adv(p).value; left = { type: "binary", op: op, left: left, right: parseAdd(p) }; }
  return left;
}

fn parseAdd(p) {
  let left = parseMul(p);
  while chk(p, "PLUS") || chk(p, "MINUS") { let op = adv(p).value; left = { type: "binary", op: op, left: left, right: parseMul(p) }; }
  return left;
}

fn parseMul(p) {
  let left = parseUnary(p);
  while chk(p, "STAR") || chk(p, "SLASH") || chk(p, "PERCENT") { let op = adv(p).value; left = { type: "binary", op: op, left: left, right: parseUnary(p) }; }
  return left;
}

fn parseUnary(p) {
  if chk(p, "NOT") { adv(p); return { type: "unary", op: "!", expr: parseUnary(p) }; }
  if chk(p, "MINUS") { adv(p); return { type: "unary", op: "-", expr: parseUnary(p) }; }
  return parsePostfix(p);
}

fn parsePostfix(p) {
  let expr = parsePrimary(p);
  let more = true;
  while more {
    more = false;
    if chk(p, "DOT") {
      adv(p);
      let field = adv(p).value;
      if chk(p, "LPAREN") {
        adv(p);
        let args = parseArgs(p);
        adv(p); // RPAREN
        expr = { type: "call", name: field, args: args };
      } else {
        expr = { type: "member", obj: expr, field: field };
      }
      more = true;
    } else if chk(p, "LBRACKET") {
      adv(p);
      let idx = parseExpr(p);
      adv(p); // RBRACKET
      expr = { type: "index", obj: expr, idx: idx };
      more = true;
    } else if chk(p, "LPAREN") && expr.type == "ident" {
      adv(p);
      let args = parseArgs(p);
      adv(p); // RPAREN
      expr = { type: "call", name: expr.name, args: args };
      more = true;
    }
  }
  return expr;
}

fn parseArgs(p) {
  let args = [];
  while chk(p, "RPAREN") != true && atEnd(p) != true {
    push(args, parseExpr(p));
    if chk(p, "COMMA") { adv(p); }
  }
  return args;
}

fn parsePrimary(p) {
  let tok = peek(p);
  if tok.type == "NUMBER" { adv(p); return { type: "num", value: tok.value }; }
  if tok.type == "STRING" { adv(p); return { type: "str", value: tok.value }; }
  if tok.type == "TRUE" { adv(p); return { type: "bool", value: true }; }
  if tok.type == "FALSE" { adv(p); return { type: "bool", value: false }; }
  if tok.type == "NULL" { adv(p); return { type: "null" }; }
  if tok.type == "IDENT" { adv(p); return { type: "ident", name: tok.value }; }
  if tok.type == "LPAREN" { adv(p); let e = parseExpr(p); adv(p); return e; }
  if tok.type == "LBRACKET" {
    adv(p);
    let elems = [];
    while chk(p, "RBRACKET") != true && atEnd(p) != true {
      push(elems, parseExpr(p));
      if chk(p, "COMMA") { adv(p); }
    }
    adv(p);
    return { type: "array", elems: elems };
  }
  if tok.type == "LBRACE" {
    adv(p);
    let props = [];
    while chk(p, "RBRACE") != true && atEnd(p) != true {
      let key = adv(p).value;
      adv(p); // COLON
      let val = parseExpr(p);
      push(props, { key: key, val: val });
      if chk(p, "COMMA") { adv(p); }
    }
    adv(p);
    return { type: "object", props: props };
  }
  adv(p);
  return { type: "unknown" };
}

fn parseAssign(p) {
  let left = parseOr(p);
  if chk(p, "ASSIGN") || chk(p, "PLUS_ASSIGN") || chk(p, "MINUS_ASSIGN") {
    let op = adv(p).value;
    let right = parseAssign(p);
    return { type: "assign", target: left, op: op, value: right };
  }
  return left;
}

fn parseBlock(p) {
  adv(p); // LBRACE
  let stmts = [];
  while chk(p, "RBRACE") != true && atEnd(p) != true {
    skipSemi(p);
    if chk(p, "RBRACE") { break; }
    push(stmts, parseStmt(p));
  }
  adv(p); // RBRACE
  return { type: "block", stmts: stmts };
}

fn skipType(p) {
  if chk(p, "IDENT") || chk(p, "TYPE") {
    adv(p);
    if chk(p, "LT") {
      adv(p);
      let depth = 1;
      while depth > 0 && atEnd(p) != true {
        if chk(p, "LT") { depth = depth + 1; }
        if chk(p, "GT") { depth = depth - 1; }
        adv(p);
      }
    }
  }
}

fn parseFnDecl(p) {
  adv(p); // FN
  let name = adv(p).value;
  adv(p); // LPAREN
  let params = [];
  while chk(p, "RPAREN") != true && atEnd(p) != true {
    push(params, adv(p).value);
    if chk(p, "COLON") { adv(p); skipType(p); }
    if chk(p, "COMMA") { adv(p); }
  }
  adv(p); // RPAREN
  if chk(p, "COLON") || chk(p, "ARROW") { adv(p); skipType(p); }
  let body = parseBlock(p);
  return { type: "fn", name: name, params: params, body: body };
}

fn parseStmt(p) {
  let tok = peek(p);
  if tok.type == "FN" { return parseFnDecl(p); }
  if tok.type == "LET" || tok.type == "CONST" {
    adv(p);
    let name = adv(p).value;
    if chk(p, "COLON") { adv(p); skipType(p); }
    let init = null;
    if chk(p, "ASSIGN") { adv(p); init = parseAssign(p); }
    skipSemi(p);
    return { type: "var", name: name, init: init };
  }
  if tok.type == "IF" {
    adv(p);
    let cond = parseAssign(p);
    let then_b = parseBlock(p);
    let else_b = null;
    if chk(p, "ELSE") { adv(p); if chk(p, "IF") { else_b = { type: "block", stmts: [parseStmt(p)] }; } else { else_b = parseBlock(p); } }
    return { type: "if", cond: cond, then: then_b, else_b: else_b };
  }
  if tok.type == "WHILE" {
    adv(p);
    let cond = parseAssign(p);
    let body = parseBlock(p);
    return { type: "while", cond: cond, body: body };
  }
  if tok.type == "RETURN" {
    adv(p);
    let val = null;
    if chk(p, "SEMICOLON") != true && chk(p, "RBRACE") != true && atEnd(p) != true {
      val = parseAssign(p);
    }
    skipSemi(p);
    return { type: "return", value: val };
  }
  if tok.type == "BREAK" { adv(p); skipSemi(p); return { type: "break" }; }
  if tok.type == "CONTINUE" { adv(p); skipSemi(p); return { type: "continue" }; }

  let expr = parseAssign(p);
  skipSemi(p);
  return { type: "expr_stmt", expr: expr };
}

fn parseProgram(tokens) {
  let p = { tokens: tokens, pos: 0, len: length(tokens) };
  let stmts = [];
  while atEnd(p) != true {
    skipSemi(p);
    if atEnd(p) { break; }
    push(stmts, parseStmt(p));
  }
  return { type: "program", stmts: stmts };
}

fn countNodes(node) {
  if node == null { return 0; }
  let c = 1;
  if node.stmts != null { let i = 0; while i < length(node.stmts) { c = c + countNodes(node.stmts[i]); i = i + 1; } }
  if node.body != null { c = c + countNodes(node.body); }
  if node.init != null { c = c + countNodes(node.init); }
  if node.cond != null { c = c + countNodes(node.cond); }
  if node.then != null { c = c + countNodes(node.then); }
  if node.left != null { c = c + countNodes(node.left); }
  if node.right != null { c = c + countNodes(node.right); }
  if node.expr != null { c = c + countNodes(node.expr); }
  if node.target != null { c = c + countNodes(node.target); }
  if node.obj != null { c = c + countNodes(node.obj); }
  if node.args != null { let i = 0; while i < length(node.args) { c = c + countNodes(node.args[i]); i = i + 1; } }
  return c;
}

// ══ CODEGEN MODULE ══

// FreeLang Self-Hosting: IR Generator
// Phase 3C — AST → IR instruction array
// Depends on: types.fl opcodes (inlined), bootstrap-v2.fl parser AST format

// ── Opcodes (inlined from types.fl) ──
let OP_PUSH = 1;
let OP_POP = 2;
let OP_PUSH_FLOAT = 4;
let OP_ADD = 16;
let OP_SUB = 17;
let OP_MUL = 18;
let OP_DIV = 19;
let OP_MOD = 20;
let OP_NEG = 21;
let OP_EQ = 32;
let OP_NEQ = 33;
let OP_LT = 34;
let OP_GT = 35;
let OP_LTE = 36;
let OP_GTE = 37;
let OP_AND = 48;
let OP_OR = 49;
let OP_NOT = 50;
let OP_STORE = 64;
let OP_LOAD = 65;
let OP_JMP = 80;
let OP_JMP_IF = 81;
let OP_JMP_NOT = 82;
let OP_CALL = 83;
let OP_RET = 84;
let OP_HALT = 95;
let OP_ARR_NEW = 96;
let OP_ARR_PUSH = 97;
let OP_ARR_GET = 98;
let OP_ARR_SET = 99;
let OP_STR_NEW = 144;
let OP_STR_CONCAT = 148;
let OP_OBJ_NEW = 192;
let OP_OBJ_SET = 193;
let OP_OBJ_GET = 194;
let OP_FUNC_DEF = 163;

// ── Helper: make IR instruction ──
fn inst(op, arg) {
  return { op: op, arg: arg };
}

// ── Helper: patch jump target (workaround for out[idx].arg = val) ──
fn patchJmp(out, idx, target) {
  let i = out[idx];
  i.arg = target;
}

// ── Binary operator → opcode mapping ──
fn binOpToCode(op) {
  if op == "+" { return OP_ADD; }
  if op == "-" { return OP_SUB; }
  if op == "*" { return OP_MUL; }
  if op == "/" { return OP_DIV; }
  if op == "%" { return OP_MOD; }
  if op == "==" { return OP_EQ; }
  if op == "!=" { return OP_NEQ; }
  if op == "<" { return OP_LT; }
  if op == ">" { return OP_GT; }
  if op == "<=" { return OP_LTE; }
  if op == ">=" { return OP_GTE; }
  if op == "&&" { return OP_AND; }
  if op == "||" { return OP_OR; }
  return -1;
}

// ── Core: traverse AST node, emit IR into out[] ──
// Loop context for break/continue
let _loopStack = [];

fn traverse(node, out) {
  if node == null { return; }
  let t = node.type;

  // ── Literals ──
  if t == "num" {
    push(out, inst(OP_PUSH, node.value));
    return;
  }
  if t == "str" {
    push(out, inst(OP_STR_NEW, node.value));
    return;
  }
  if t == "bool" {
    if node.value { push(out, inst(OP_PUSH, 1)); }
    else { push(out, inst(OP_PUSH, 0)); }
    return;
  }
  if t == "null" {
    push(out, inst(OP_PUSH, null));
    return;
  }

  // ── Identifier ──
  if t == "ident" {
    push(out, inst(OP_LOAD, node.name));
    return;
  }

  // ── Binary ──
  if t == "binary" {
    traverse(node.left, out);
    traverse(node.right, out);
    let opCode = binOpToCode(node.op);
    if opCode == -1 {
      // string concat for "+"
      push(out, inst(OP_STR_CONCAT, null));
    } else {
      push(out, inst(opCode, null));
    }
    return;
  }

  // ── Unary ──
  if t == "unary" {
    traverse(node.expr, out);
    if node.op == "-" { push(out, inst(OP_NEG, null)); }
    else if node.op == "!" { push(out, inst(OP_NOT, null)); }
    return;
  }

  // ── Call ──
  if t == "call" {
    if node.args != null {
      let i = 0;
      while i < length(node.args) {
        traverse(node.args[i], out);
        i = i + 1;
      }
    }
    push(out, inst(OP_CALL, node.name));
    return;
  }

  // ── Member access: obj.field ──
  if t == "member" {
    traverse(node.obj, out);
    push(out, inst(OP_STR_NEW, node.field));
    push(out, inst(OP_OBJ_GET, null));
    return;
  }

  // ── Index access: obj[idx] ──
  if t == "index" {
    traverse(node.obj, out);
    traverse(node.idx, out);
    push(out, inst(OP_ARR_GET, null));
    return;
  }

  // ── Array literal ──
  if t == "array" {
    push(out, inst(OP_ARR_NEW, null));
    let i = 0;
    while i < length(node.elems) {
      traverse(node.elems[i], out);
      push(out, inst(OP_ARR_PUSH, null));
      i = i + 1;
    }
    return;
  }

  // ── Object literal ──
  if t == "object" {
    push(out, inst(OP_OBJ_NEW, null));
    let i = 0;
    while i < length(node.props) {
      push(out, inst(OP_STR_NEW, node.props[i].key));
      traverse(node.props[i].val, out);
      push(out, inst(OP_OBJ_SET, null));
      i = i + 1;
    }
    return;
  }

  // ── Assignment: target = value ──
  if t == "assign" {
    traverse(node.value, out);
    if node.target.type == "ident" {
      push(out, inst(OP_STORE, node.target.name));
    } else if node.target.type == "index" {
      // arr[i] = val → val already on stack
      traverse(node.target.obj, out);
      traverse(node.target.idx, out);
      push(out, inst(OP_ARR_SET, null));
    } else if node.target.type == "member" {
      // obj.field = val
      traverse(node.target.obj, out);
      push(out, inst(OP_STR_NEW, node.target.field));
      push(out, inst(OP_OBJ_SET, null));
    }
    return;
  }

  // ── Variable declaration ──
  if t == "var" {
    if node.init != null {
      traverse(node.init, out);
    } else {
      push(out, inst(OP_PUSH, null));
    }
    push(out, inst(OP_STORE, node.name));
    return;
  }

  // ── If statement ──
  if t == "if" {
    traverse(node.cond, out);
    let jmpNotIdx = length(out);
    push(out, inst(OP_JMP_NOT, 0)); // placeholder
    traverse(node.then, out);
    if node.else_b != null {
      let jmpEndIdx = length(out);
      push(out, inst(OP_JMP, 0)); // placeholder
      patchJmp(out, jmpNotIdx, length(out)); // patch: jump to else
      traverse(node.else_b, out);
      patchJmp(out, jmpEndIdx, length(out)); // patch: jump to end
    } else {
      patchJmp(out, jmpNotIdx, length(out)); // patch: jump past then
    }
    return;
  }

  // ── While statement ──
  if t == "while" {
    let loopStart = length(out);
    // Push loop context for break/continue
    let loopCtx = { start: loopStart, breaks: [] };
    push(_loopStack, loopCtx);

    traverse(node.cond, out);
    let jmpNotIdx = length(out);
    push(out, inst(OP_JMP_NOT, 0)); // placeholder

    traverse(node.body, out);
    push(out, inst(OP_JMP, loopStart)); // loop back

    let loopEnd = length(out);
    patchJmp(out, jmpNotIdx, loopEnd); // patch: exit loop

    // Patch all break jumps
    let bi = 0;
    while bi < length(loopCtx.breaks) {
      patchJmp(out, loopCtx.breaks[bi], loopEnd);
      bi = bi + 1;
    }

    // Pop loop context
    pop(_loopStack);
    return;
  }

  // ── Return ──
  if t == "return" {
    if node.value != null {
      traverse(node.value, out);
    } else {
      push(out, inst(OP_PUSH, null));
    }
    push(out, inst(OP_RET, null));
    return;
  }

  // ── Break ──
  if t == "break" {
    if length(_loopStack) > 0 {
      let ctx = _loopStack[length(_loopStack) - 1];
      let breakIdx = length(out);
      push(out, inst(OP_JMP, 0)); // placeholder, patched later
      push(ctx.breaks, breakIdx);
    }
    return;
  }

  // ── Continue ──
  if t == "continue" {
    if length(_loopStack) > 0 {
      let ctx = _loopStack[length(_loopStack) - 1];
      push(out, inst(OP_JMP, ctx.start));
    }
    return;
  }

  // ── Function declaration ──
  if t == "fn" {
    let bodyIR = [];
    traverse(node.body, bodyIR);
    // Ensure function ends with RET
    if length(bodyIR) == 0 || bodyIR[length(bodyIR) - 1].op != OP_RET {
      push(bodyIR, inst(OP_PUSH, null));
      push(bodyIR, inst(OP_RET, null));
    }
    push(out, { op: OP_FUNC_DEF, arg: node.name, params: node.params, sub: bodyIR });
    return;
  }

  // ── Block ──
  if t == "block" {
    let i = 0;
    while i < length(node.stmts) {
      traverse(node.stmts[i], out);
      i = i + 1;
    }
    return;
  }

  // ── Expression statement ──
  if t == "expr_stmt" {
    traverse(node.expr, out);
    push(out, inst(OP_POP, null));
    return;
  }

  // ── Program (top-level) ──
  if t == "program" {
    let i = 0;
    while i < length(node.stmts) {
      traverse(node.stmts[i], out);
      i = i + 1;
    }
    push(out, inst(OP_HALT, null));
    return;
  }

  // Unknown node type — skip with warning
  println("WARN: unknown AST type: " + t);
}

// ── Public API ──
fn generateIR(ast) {
  let out = [];
  traverse(ast, out);
  return out;
}

// ── IR debug printer ──
fn opName(op) {
  if op == 1 { return "PUSH"; }
  if op == 2 { return "POP"; }
  if op == 4 { return "PUSH_FLOAT"; }
  if op == 16 { return "ADD"; }
  if op == 17 { return "SUB"; }
  if op == 18 { return "MUL"; }
  if op == 19 { return "DIV"; }
  if op == 20 { return "MOD"; }
  if op == 21 { return "NEG"; }
  if op == 32 { return "EQ"; }
  if op == 33 { return "NEQ"; }
  if op == 34 { return "LT"; }
  if op == 35 { return "GT"; }
  if op == 36 { return "LTE"; }
  if op == 37 { return "GTE"; }
  if op == 48 { return "AND"; }
  if op == 49 { return "OR"; }
  if op == 50 { return "NOT"; }
  if op == 64 { return "STORE"; }
  if op == 65 { return "LOAD"; }
  if op == 80 { return "JMP"; }
  if op == 81 { return "JMP_IF"; }
  if op == 82 { return "JMP_NOT"; }
  if op == 83 { return "CALL"; }
  if op == 84 { return "RET"; }
  if op == 95 { return "HALT"; }
  if op == 96 { return "ARR_NEW"; }
  if op == 97 { return "ARR_PUSH"; }
  if op == 98 { return "ARR_GET"; }
  if op == 99 { return "ARR_SET"; }
  if op == 144 { return "STR_NEW"; }
  if op == 148 { return "STR_CONCAT"; }
  if op == 163 { return "FUNC_DEF"; }
  if op == 192 { return "OBJ_NEW"; }
  if op == 193 { return "OBJ_SET"; }
  if op == 194 { return "OBJ_GET"; }
  return "OP_" + str(op);
}

fn printIR(ir) {
  let i = 0;
  while i < length(ir) {
    let name = opName(ir[i].op);
    if ir[i].arg != null {
      println("  " + str(i) + ": " + name + " " + str(ir[i].arg));
    } else {
      println("  " + str(i) + ": " + name);
    }
    i = i + 1;
  }
}

// ══ INTEGRATION TEST ══

fn main() {
  println("=== Phase 3D: Self-Compile Integration ===");

  // T1: simple expression
  let t1 = tokenize("let x = 1 + 2;");
  let a1 = parseProgram(t1);
  let i1 = generateIR(a1);
  let r1 = "FAIL";
  if i1[length(i1)-1].op == 95 { r1 = "PASS"; }
  println("T1: " + str(length(t1)) + " tok → " + str(length(i1)) + " IR  " + r1);

  // T2: function + call
  let t2 = tokenize("fn add(a, b) { return a + b; }\nlet r = add(3, 4);");
  let a2 = parseProgram(t2);
  let i2 = generateIR(a2);
  let r2 = "FAIL";
  if i2[length(i2)-1].op == 95 { r2 = "PASS"; }
  println("T2: " + str(length(t2)) + " tok → " + str(length(i2)) + " IR  " + r2);

  // T3: if/else
  let t3 = tokenize("let x = 10;\nif x > 5 { println(x); } else { println(0); }");
  let a3 = parseProgram(t3);
  let i3 = generateIR(a3);
  let r3 = "FAIL";
  if i3[length(i3)-1].op == 95 { r3 = "PASS"; }
  println("T3: " + str(length(t3)) + " tok → " + str(length(i3)) + " IR  " + r3);

  // T4: while loop
  let t4 = tokenize("let i = 0;\nwhile i < 5 { i = i + 1; }");
  let a4 = parseProgram(t4);
  let i4 = generateIR(a4);
  let r4 = "FAIL";
  if i4[length(i4)-1].op == 95 { r4 = "PASS"; }
  println("T4: " + str(length(t4)) + " tok → " + str(length(i4)) + " IR  " + r4);

  // T5: self-compile codegen-v2.fl
  println("");
  println("T5: Self-compiling codegen-v2.fl...");
  let cgSrc = file_read("self-hosting/codegen-v2.fl");
  let cgTok = tokenize(cgSrc);
  println("  Tokens: " + str(length(cgTok)));
  let cgAst = parseProgram(cgTok);
  println("  AST: " + str(length(cgAst.stmts)) + " stmts, " + str(countNodes(cgAst)) + " nodes");
  let cgIR = generateIR(cgAst);
  println("  IR: " + str(length(cgIR)) + " instructions");
  if cgIR[length(cgIR)-1].op == 95 {
    println("  PASS: codegen self-compiled!");
  }

  println("");
  println("=== Phase 3D COMPLETE ===");
}
