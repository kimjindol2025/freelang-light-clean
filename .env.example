# FreeLang Light - 환경 설정 템플릿
# 사용법: cp .env.example .env 후 필요한 값 수정

# ============================================
# 서버 설정
# ============================================
NODE_ENV=production
PORT=4002
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================
# 데이터베이스 설정
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=freelang_light
DB_USER=freelang_user
# DB_PASSWORD 는 .env 파일에만 작성 (git 추적 X)
DB_SSL=true

# ============================================
# Redis 설정 (캐싱)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD 는 .env 파일에만 작성 (git 추적 X)

# ============================================
# OAuth2 설정
# ============================================
OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
# OAUTH_GOOGLE_CLIENT_SECRET 는 .env 파일에만 작성 (git 추적 X)
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:4002/auth/google/callback

OAUTH_GITHUB_CLIENT_ID=your_github_client_id
# OAUTH_GITHUB_CLIENT_SECRET 는 .env 파일에만 작성 (git 추적 X)
OAUTH_GITHUB_REDIRECT_URI=http://localhost:4002/auth/github/callback

# ============================================
# JWT 토큰 설정
# ============================================
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
# JWT_SECRET 는 .env 파일에만 작성 (git 추적 X)

# ============================================
# 모니터링 & 로깅
# ============================================
GRAFANA_ENABLED=true
GRAFANA_HOST=localhost
GRAFANA_PORT=3000
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================
# 이메일 설정
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=noreply@freelang.io
# SMTP_PASSWORD 는 .env 파일에만 작성 (git 추적 X)

# ============================================
# API 키 설정
# ============================================
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
# STRIPE_SECRET_KEY 는 .env 파일에만 작성 (git 추적 X)

# ============================================
# 배포 설정
# ============================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
# DOCKER_PASSWORD 는 .env 파일에만 작성 (git 추적 X)

# ============================================
# 개발 전용 설정 (production에서는 비활성화)
# ============================================
DEBUG=false
DEMO_MODE=false
